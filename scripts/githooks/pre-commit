#!/usr/bin/env bash
# TRsim pre-commit hook — bindfs truncation 감지 + ruff check + format.
#
# 활성화 (한 번만, 저장소 루트에서):
#   $ git config core.hooksPath scripts/githooks
#
# bypass:
#   $ git commit --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# staged 인 .py 파일만 — 삭제는 제외 (--diff-filter=ACM)
mapfile -t PY_FILES < <(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

if [ ${#PY_FILES[@]} -eq 0 ]; then
    exit 0
fi

echo "[pre-commit] checking ${#PY_FILES[@]} staged .py file(s)"

# --- 1. truncation 검사 (bindfs sync 트랩) ---
# Python 으로 ast 파싱 — syntax error 면 잘렸을 가능성 매우 높음.
# .venv Python 우선 (system python 미설치/깨진 install 환경 회피).
PY=""
if [ -x ".venv/Scripts/python.exe" ]; then
    PY=".venv/Scripts/python.exe"
elif [ -x ".venv/bin/python" ]; then
    PY=".venv/bin/python"
elif command -v python >/dev/null 2>&1; then
    PY="python"
fi

if [ -z "$PY" ]; then
    echo "[pre-commit] WARN — python 미발견. truncation 검사 skip."
else
    TRUNC_FAIL=0
    for f in "${PY_FILES[@]}"; do
        if [ ! -f "$f" ]; then continue; fi
        # 첫 fail 의 stderr 는 보존해서 진단 가능하게 (file 별 capture).
        ERR=$("$PY" -m py_compile "$f" 2>&1) || {
            echo "  [TRUNC] $f — py_compile 실패."
            echo "          stderr: $ERR"
            echo "          tail 확인:"
            tail -5 "$f" | sed 's/^/            /'
            TRUNC_FAIL=1
        }
    done
    if [ $TRUNC_FAIL -ne 0 ]; then
        echo ""
        echo "[pre-commit] FAIL — truncation 감지. 파일 재저장 후 재시도."
        echo "             (모든 파일 fail 이면 환경 문제 — '$PY' 점검)"
        exit 1
    fi
fi

# --- 2. ruff check (lint) ---
# .venv 의 ruff 자동 탐색 (activate 안 된 상태에서도 작동)
RUFF=""
if command -v ruff >/dev/null 2>&1; then
    RUFF="ruff"
elif [ -x ".venv/Scripts/ruff.exe" ]; then
    RUFF=".venv/Scripts/ruff.exe"
elif [ -x ".venv/bin/ruff" ]; then
    RUFF=".venv/bin/ruff"
fi

if [ -z "$RUFF" ]; then
    echo "[pre-commit] WARN — ruff 설치 안 됨. uv pip install -e \".[dev]\" 권장."
else
    if ! "$RUFF" check --quiet "${PY_FILES[@]}"; then
        echo "[pre-commit] FAIL — ruff check 위반. '$RUFF check --fix' 시도 후 재 add."
        exit 1
    fi
    if ! "$RUFF" format --check --quiet "${PY_FILES[@]}"; then
        echo "[pre-commit] FAIL — ruff format 미적용. '$RUFF format' 후 재 add."
        exit 1
    fi
fi

echo "[pre-commit] OK"
exit 0
