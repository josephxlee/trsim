# name = PyVista must only be imported within ui.simulator.scene_3d
# type = forbidden
# source_modules =
#     workbench.ui.editor
#     workbench.ui.simulator.fft_panel
#     workbench.ui.simulator.range_doppler_panel
#     workbench.ui.simulator.run_panel
#     workbench.ui.simulator.properties_panel
#     workbench.ui.simulator.stage_io_panel
#     workbench.ui.simulator.physics_validation_panel
#     workbench.ui.simulator.plugin_manager_panel
#     workbench.app
#     workbench.domain
#     workbench.physics
# forbidden_modules =
#     pyvista
#     vtk
#
# # === Contract 6: NN 격리 (Torch/sklearn은 app/nn, ui/simulator/nn_mode 안에만) ===
# [importlinter:contract:nn-isolation]
# name = Torch/sklearn must only be imported in nn modules
# type = forbidden
