# .importlinter — 의존성 규칙 자동 검사 (plan/02 § 2.5)
# CI 에서 `lint-imports` 명령 실행.
#
# Phase 0.4 시점: 일부 모듈이 아직 없어 활성화하면 import-linter 가 source_modules
# 미존재 에러로 fail. Phase 별로 활성화:
#   - Contract 1 (layer-stack)        : 활성 — 모든 패키지 존재
#   - Contract 2 (workspace-isolation): 활성 — ui.editor/ui.simulator 디렉토리 존재
#   - Contract 3 (domain-purity)      : 활성
#   - Contract 4 (sdk-dependency)     : 활성
#   - Contract 5 (pyvista-isolation)  : 비활성 — Phase 4 (UI 구현 시) 활성. 개별 패널 모듈 미존재.
#   - Contract 6 (nn-isolation)       : 비활성 — Phase 6 (NN 통합) 활성. workbench.io 등 미존재 가능.

[importlinter]
root_packages =
    workbench
# True: external packages (PySide6, pyqtgraph, pyvista 등) 도 추적해
# Contract 3/4 의 forbidden_modules 검사가 가능. plan/02 § 2.5 의 Domain 순수성 강제.
include_external_packages = True


# === Contract 1: 계층 의존 (UI → App → SDK → Domain → Physics) ===
[importlinter:contract:layer-stack]
name = Layer dependency stack (one-way)
type = layers
layers =
    workbench.ui
    workbench.app
    workbench.sdk
    workbench.domain
    workbench.physics


# === Contract 2: Workspace 격리 (Editor ↔ Simulator 직접 참조 금지) ===
[importlinter:contract:workspace-isolation]
name = Editor and Simulator workspaces must not import each other
type = forbidden
source_modules =
    workbench.ui.editor
forbidden_modules =
    workbench.ui.simulator

[importlinter:contract:workspace-isolation-reverse]
name = Simulator must not import Editor
type = forbidden
source_modules =
    workbench.ui.simulator
forbidden_modules =
    workbench.ui.editor


# === Contract 3: Domain 순수성 (Qt·시각화 의존 금지) ===
[importlinter:contract:domain-purity]
name = Domain layer must not depend on Qt or visualization
type = forbidden
source_modules =
    workbench.domain
    workbench.physics
forbidden_modules =
    PySide6
    pyqtgraph
    pyvista
    vtk
    workbench.ui


# === Contract 4: SDK 의존 (Domain만 import, App·UI 직접 참조 금지) ===
[importlinter:contract:sdk-dependency]
name = SDK must only import Domain (not App, UI)
type = forbidden
source_modules =
    workbench.sdk
forbidden_modules =
    workbench.app
    workbench.ui
    PySide6
    pyqtgraph
    pyvista


# ======================================================================
# Contract 5 + 6: Phase 4 / Phase 6 활성화 후보 (현재 비활성)
# ======================================================================
#
# 활성화 시점:
#   - Contract 5: ui/simulator/{fft_panel,range_doppler_panel,...} 파일 생성 후 (Phase 4)
#   - Contract 6: workbench.io 디렉토리에 실제 모듈 추가 후 (Phase 3)
#
# 활성화 방법: 아래 주석 해제 + Phase 시작 시 본 .importlinter 갱신
#
# # === Contract 5: Visualization 격리 (PyVista는 scene_3d 안으로만) ===
